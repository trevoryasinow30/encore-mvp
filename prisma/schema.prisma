// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider      = "prisma-client-js"
  binaryTargets = []
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  username  String   @unique
  email     String?  @unique
  password  String?  // hashed password for simple auth
  bio       String?
  createdAt DateTime @default(now())

  trades       Trade[]
  positions    Position[]
  ledger       Ledger[]
  watchlist    Watchlist[]
  priceAlerts  PriceAlert[]
  limitOrders  LimitOrder[]
  settings     UserSettings?

  @@index([username])
}

model Song {
  id              String   @id @default(cuid())
  title           String
  artistName      String
  isCover         Boolean  @default(false)
  releaseYear     Int?
  spotifyTrackId  String?
  appleMusicId    String?
  youtubeId       String?
  albumImageUrl   String?
  artistImageUrl  String?
  createdAt       DateTime @default(now())

  marketState  MarketState?
  lastfmMetric LastfmMetric?
  priceHistory PriceHistory[]
  trades       Trade[]
  positions    Position[]
  watchlist    Watchlist[]
  priceAlerts  PriceAlert[]
  limitOrders  LimitOrder[]

  @@index([title])
  @@index([artistName])
  @@index([isCover])
  @@index([releaseYear])
}

model LastfmMetric {
  songId          String   @id
  song            Song     @relation(fields: [songId], references: [id], onDelete: Cascade)
  playcount       Decimal  @db.Decimal(20, 0) @default(0)
  listeners       Decimal  @db.Decimal(20, 0) @default(0)
  playcountDelta  Decimal  @db.Decimal(20, 0) @default(0)
  syncedAt        DateTime @default(now())

  @@index([syncedAt])
  @@index([playcount])
  @@index([playcountDelta])
}

model MarketState {
  id            String   @id @default(cuid())
  songId        String   @unique
  song          Song     @relation(fields: [songId], references: [id], onDelete: Cascade)

  price         Decimal  @db.Decimal(10, 2)
  change24hPct  Decimal  @db.Decimal(10, 2) @default(0)
  volume24h     Decimal  @db.Decimal(15, 2) @default(0)
  traders24h    Int      @default(0)
  tags          String[] // array of tags like ["RE-EMERGING", "TIKTOK_SPIKE"]

  lastUpdatedAt DateTime @default(now())

  @@index([price])
  @@index([change24hPct])
  @@index([volume24h])
}

enum TradeSide {
  BUY
  SELL
}

model Trade {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id])
  songId    String
  song      Song      @relation(fields: [songId], references: [id])

  side      TradeSide
  qty       Decimal   @db.Decimal(15, 4) // allow fractional shares
  price     Decimal   @db.Decimal(10, 2)
  total     Decimal   @db.Decimal(15, 2) // qty * price

  createdAt DateTime  @default(now())

  @@index([userId])
  @@index([songId])
  @@index([createdAt])
}

model Position {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  songId    String
  song      Song     @relation(fields: [songId], references: [id])

  qty       Decimal  @db.Decimal(15, 4)
  avgCost   Decimal  @db.Decimal(10, 2)

  updatedAt DateTime @updatedAt

  @@unique([userId, songId])
  @@index([userId])
  @@index([songId])
}

enum LedgerType {
  DEPOSIT
  TRADE
  ADJUST
}

model Ledger {
  id           String     @id @default(cuid())
  userId       String
  user         User       @relation(fields: [userId], references: [id])

  type         LedgerType
  amount       Decimal    @db.Decimal(15, 2) // positive or negative
  balanceAfter Decimal    @db.Decimal(15, 2)
  description  String?

  createdAt    DateTime   @default(now())

  @@index([userId])
  @@index([createdAt])
}

model PriceHistory {
  id        String   @id @default(cuid())
  songId    String
  song      Song     @relation(fields: [songId], references: [id], onDelete: Cascade)

  price     Decimal  @db.Decimal(10, 2)
  volume    Decimal  @db.Decimal(15, 2) @default(0)

  createdAt DateTime @default(now())

  @@index([songId])
  @@index([createdAt])
  @@index([songId, createdAt])
}

// Watchlist - users can watch songs
model Watchlist {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  songId    String
  song      Song     @relation(fields: [songId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([userId, songId])
  @@index([userId])
  @@index([songId])
}

enum AlertType {
  PRICE_ABOVE
  PRICE_BELOW
  CHANGE_PERCENT
}

// Price Alerts - notify when conditions are met
model PriceAlert {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  songId      String
  song        Song      @relation(fields: [songId], references: [id], onDelete: Cascade)

  type        AlertType
  targetValue Decimal   @db.Decimal(10, 2) // target price or percent
  isActive    Boolean   @default(true)
  triggered   Boolean   @default(false)
  triggeredAt DateTime?

  createdAt   DateTime  @default(now())

  @@index([userId])
  @@index([songId])
  @@index([isActive])
}

enum OrderStatus {
  PENDING
  FILLED
  CANCELLED
  EXPIRED
}

// Limit Orders - execute automatically when price is reached
model LimitOrder {
  id         String      @id @default(cuid())
  userId     String
  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  songId     String
  song       Song        @relation(fields: [songId], references: [id], onDelete: Cascade)

  side       TradeSide
  qty        Decimal     @db.Decimal(15, 4)
  limitPrice Decimal     @db.Decimal(10, 2)
  status     OrderStatus @default(PENDING)

  expiresAt  DateTime?
  filledAt   DateTime?
  createdAt  DateTime    @default(now())

  @@index([userId])
  @@index([songId])
  @@index([status])
}

// User Settings - preferences like dark mode
model UserSettings {
  id          String  @id @default(cuid())
  userId      String  @unique
  user        User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  darkMode    Boolean @default(false)
  emailAlerts Boolean @default(true)
  pushAlerts  Boolean @default(true)

  updatedAt   DateTime @updatedAt
}
